# Copy this file to .env and edit as needed
POSTGRES_USER=facedetect
POSTGRES_PASSWORD=facedetect_secret
POSTGRES_DB=facedetect_db

SECRET_KEY=supersecretkey_change_in_production_please

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Frontend origin(s) allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost

# Host port nginx binds to
HOST_PORT=80

# Vite env (build-time; leave blank to use nginx proxy)
VITE_API_BASE=
